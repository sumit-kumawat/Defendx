<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 120" width="500" height="120">
  <!-- Professional Shield & Key Cyber Defense Emblem -->
  <defs>
    <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#2045B4" />
      <stop offset="100%" stop-color="#0f7aa5" />
    </linearGradient>
    <linearGradient id="accentGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#38bdf8" />
      <stop offset="100%" stop-color="#0369a1" />
    </linearGradient>
  </defs>
  <g transform="translate(10, 10)">
    <!-- Outer Shield -->
    <path d="M 50 0 L 90 20 L 90 60 C 90 90, 50 105, 50 105 C 50 105, 10 90, 10 60 L 10 20 Z" fill="url(#shieldGrad)" />
    <!-- Inner design lines -->
    <path d="M 50 8 L 82 24 L 82 56 C 82 80, 50 93, 50 93 C 50 93, 18 80, 18 56 L 18 24 Z" fill="none" stroke="#ffffff" stroke-width="2" stroke-opacity="0.3" />
    <!-- Core Defense Icon (Lock/Shield) -->
    <path d="M 42 42 L 42 58 L 58 58 L 58 42 Z" fill="none" stroke="#ffffff" stroke-width="3.5" stroke-linejoin="round" />
    <path d="M 46 42 L 46 38 C 46 34, 54 34, 54 38 L 54 42" fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round" />
    <circle cx="50" cy="50" r="2" fill="#ffffff" />
    <!-- Digital Data Nodes -->
    <circle cx="28" cy="30" r="3" fill="url(#accentGrad)" />
    <circle cx="72" cy="30" r="3" fill="url(#accentGrad)" />
    <circle cx="50" cy="80" r="4" fill="url(#accentGrad)" />
  </g>
  <!-- DefendX Modern Technology Typography -->
  <text x="125" y="65" font-family="'Inter', 'Segoe UI', system-ui, sans-serif" font-size="44" font-weight="900" fill="#1e293b" letter-spacing="1">DEFEND<tspan fill="#2045B4">X</tspan></text>
  <text x="127" y="88" font-family="'Segoe UI', system-ui, sans-serif" font-size="10.5" font-weight="800" fill="#64748b" letter-spacing="4">SECURE TELEMETRY ARRAYS</text>
</svg>
