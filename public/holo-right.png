<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100" height="100">
  <defs>
    <linearGradient id="rightHoloGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0f7aa5" />
      <stop offset="50%" stop-color="#2045B4" />
      <stop offset="100%" stop-color="#1e1b4b" />
    </linearGradient>
  </defs>
  <!-- Decorative High-Tech Mesh Core -->
  <circle cx="50" cy="50" r="46" fill="url(#rightHoloGrad2)" stroke="#38bdf8" stroke-width="2" />
  <circle cx="50" cy="50" r="38" fill="none" stroke="#60a5fa" stroke-width="1" stroke-dasharray="2 4" />
  
  <!-- Crossed Security Keys/Nodes -->
  <g stroke="#ffffff" stroke-width="1.5" fill="none" stroke-opacity="0.9">
    <line x1="25" y1="25" x2="75" y2="75" />
    <line x1="75" y1="25" x2="25" y2="75" />
    <line x1="15" y1="50" x2="85" y2="50" />
    <line x1="50" y1="15" x2="50" y2="85" />
  </g>
  
  <circle cx="50" cy="50" r="24" fill="#1e1b4b" stroke="#fef08a" stroke-width="2.5" />
  
  <!-- Text inside badge -->
  <text x="50" y="44" font-family="'Segoe UI', system-ui, sans-serif" font-size="7" font-weight="900" fill="#fef08a" text-anchor="middle" letter-spacing="1">DEFENDX</text>
  <text x="50" y="53" font-family="'Segoe UI', system-ui, sans-serif" font-size="5" font-weight="800" fill="#ffffff" text-anchor="middle" letter-spacing="0.5">SECURE</text>
  <text x="50" y="61" font-family="'Segoe UI', system-ui, sans-serif" font-size="5.5" font-weight="950" fill="#4ade80" text-anchor="middle" letter-spacing="0.5">VERIFIED</text>
  
  <!-- Outer glowing node ring dots -->
  <circle cx="50" cy="14" r="2.5" fill="#4ade80" />
  <circle cx="50" cy="86" r="2.5" fill="#4ade80" />
  <circle cx="14" cy="50" r="2.5" fill="#4ade80" />
  <circle cx="86" cy="50" r="2.5" fill="#4ade80" />
</svg>
