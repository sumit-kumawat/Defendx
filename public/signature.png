<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 250 80" width="250" height="80">
  <!-- Elegant cursive authority signature path with metallic gradient ink -->
  <defs>
    <linearGradient id="signatureInk" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1d4ed8" />
      <stop offset="60%" stop-color="#1e3a8a" />
      <stop offset="100%" stop-color="#0f172a" />
    </linearGradient>
  </defs>
  <!-- Beautiful fluid calligraphic paths -->
  <path d="M 20 50 C 40 10, 60 15, 65 35 C 70 55, 50 65, 75 40 C 95 20, 100 30, 95 50 C 90 70, 110 50, 125 35 C 140 20, 145 35, 135 55 C 125 75, 150 45, 165 30 C 180 15, 185 30, 175 48 C 165 66, 190 40, 205 32 C 220 24, 230 40, 215 52 C 200 64, 225 45, 235 38" 
        fill="none" stroke="url(#signatureInk)" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
  
  <path d="M 15 54 C 45 52, 90 56, 135 52 C 180 48, 210 50, 240 44" 
        fill="none" stroke="url(#signatureInk)" stroke-width="1.8" stroke-opacity="0.8" stroke-linecap="round" />
</svg>
